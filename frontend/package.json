{
  "name": "tabby",
  "version": "0.1.2",
  "private": true,
  "main": "build/main.js",
  "description": "AI Keyboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/CubeStar1/ai-keyboard.git"
  },
  "scripts": {
    "build": "run-s next:build electron:build",
    "dev": "npm-run-all --parallel electron:dev next:dev",
    "dist": "run-s build electron:dist",
    "electron:build_watch": "tsup --watch",
    "electron:build": "tsup",
    "electron:dev": "npm-run-all --parallel electron:build_watch electron:watch",
    "electron:dist:deb": "electron-builder --linux deb",
    "electron:dist": "electron-builder",
    "electron:watch": "cross-env NODE_ENV='development' nodemon",
    "format": "dprint fmt",
    "next:build": "next build --turbopack",
    "next:dev": "next dev --turbopack",
    "next:lint": "eslint",
    "next:start": "next start",
    "postinstall": "electron-builder install-app-deps",
    "windows-mcp": "uvx windows-mcp --transport streamable-http --port 8001",
    "leetcode-mcp": "npx -y @jinzcdev/leetcode-mcp-server --site global",
    "typecheck": "tsc --noEmit",
    "release": "node -e \"const v=require('./package.json').version; require('child_process').execSync(`git tag v${v} && git push origin --tags`, {stdio: 'inherit'})\""
  },
  "dependencies": {
    "@ai-sdk/cerebras": "^2.0.5",
    "@ai-sdk/devtools": "^0.0.4",
    "@ai-sdk/google": "^3.0.6",
    "@ai-sdk/groq": "^3.0.4",
    "@ai-sdk/mcp": "^1.0.5",
    "@ai-sdk/openai": "^3.0.7",
    "@ai-sdk/openai-compatible": "^2.0.10",
    "@ai-sdk/react": "^3.0.23",
    "@ai-sdk/ui-utils": "^1.2.11",
    "@electron-toolkit/utils": "^4.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@neo4j-nvl/base": "^1.0.0",
    "@neo4j-nvl/react": "^1.0.0",
    "@next/env": "^15.5.4",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-email/components": "^0.5.7",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-query": "^5.90.16",
    "@tavily/core": "^0.5.8",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "electron-store": "^11.0.2",
    "embla-carousel-react": "^8.6.0",
    "get-port-please": "^3.2.0",
    "input-otp": "^1.4.2",
    "lru-cache": "^11.2.4",
    "lucide-react": "^0.562.0",
    "motion": "^12.24.12",
    "nanoid": "^5.1.6",
    "next": "^15.5.4",
    "next-themes": "^0.4.6",
    "node-window-manager": "^2.2.4",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "2.15.4",
    "resend": "^4.1.2",
    "sharp": "^0.34.4",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "streamdown": "^1.6.11",
    "tailwind-merge": "^3.4.0",
    "tokenlens": "^1.3.1",
    "uiohook-napi": "^1.5.4",
    "use-stick-to-bottom": "^1.1.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "cross-env": "^10.1.0",
    "dprint": "^0.50.2",
    "electron": "^38.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.4",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "build": {
    "asar": true,
    "productName": "Tabby",
    "executableName": "Tabby",
    "appId": "com.tabby.ai-keyboard",
    "publish": [
      {
        "provider": "github",
        "owner": "CubeStar1",
        "repo": "ai-keyboard",
        "releaseType": "draft"
      }
    ],
    "releaseInfo": {
      "releaseName": "v${version}"
    },
    "icon": "public/icons/icon.png",
    "asarUnpack": [
      "public",
      "node_modules/next",
      "node_modules/@img",
      "node_modules/sharp",
      "**\\*.{node,dll}"
    ],
    "files": [
      "build",
      "public",
      {
        "from": ".next/standalone",
        "to": "app",
        "filter": [
          "!**/.env",
          "!**/package.json"
        ]
      },
      {
        "from": ".next/static",
        "to": "app/.next/static"
      },
      {
        "from": "public",
        "to": "app/public"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icons/icon.ico",
      "uninstallerIcon": "public/icons/icon.ico",
      "installerHeaderIcon": "public/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tabby"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icons/icon.ico"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Development",
      "icon": "public/icons"
    }
  }
}
